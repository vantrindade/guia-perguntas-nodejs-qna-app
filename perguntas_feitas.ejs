<%- include('./partials/header.ejs') %>

<body>
    <%- include('./partials/navbar.ejs') %>

    <div class="container">
        <hr>
        <h1> Perguntas </h1>
        <hr>
        <a href="/realize_uma_pergunta" class="btn btn-primary"> faça um pergunta </a>
        <hr>
        <br>
        <% perguntas.forEach(pergunta => { %>
            <br>
            <div class="card">
                <div class="card-body">
                    <h3><%= pergunta.titulo %></h3>
                    <hr>
                    <p><%= pergunta.descricao %></p>
                </div>
                <div class="card-footer">
                    <a href="/pergunta_extenso/<%= pergunta.id%>" ><button class="btn btn-primary">Responder</button></a>
                   
                </div> 
                
                <div class="card-footer">
                    <form action="/apagarpergunta" method="POST">
                        <input type="hidden" name="id" value="<%= pergunta.id %>">
                        <button class="btn btn-danger " type="submit">Apagar</button>
                    </form>
                </div>
                
            </div>
                <br>
            <% }) %>
    </div>

</body>
<%- include('./partials/footer.ejs') %>


